# Server
PORT=3000
NODE_ENV=development

# Neon Postgres — get both URLs from your Neon dashboard
# DATABASE_URL uses the pooler (pgbouncer) for runtime queries
# DIRECT_URL bypasses the pooler — required for Prisma migrations
DATABASE_URL="postgresql://user:password@ep-xxx.neon.tech/dbname?sslmode=require&pgbouncer=true"
DIRECT_URL="postgresql://user:password@ep-xxx.neon.tech/dbname?sslmode=require"

# AI Provider — "openai" or "gemini"
AI_PROVIDER=openai
OPENAI_API_KEY=sk-...
GEMINI_API_KEY=

# SMTP — leave blank to log emails to console in dev
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Frontend URL for CORS
CORS_ORIGIN=http://localhost:5173
